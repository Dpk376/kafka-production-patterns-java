{
  "title": "Kafka Resilience Patterns Dashboard",
  "uid": "kafka-patterns-dx",
  "schemaVersion": 30,
  "timezone": "browser",
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Consumer Lag (Max)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "max(kafka_consumer_fetch_manager_records_lag_max) by (client_id, topic)",
          "legendFormat": "{{client_id}} - {{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Message Throughput (Consumed vs Published)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(kafka_consumer_fetch_manager_records_consumed_total[1m])",
          "legendFormat": "Consumed ({{client_id}})"
        },
        {
          "expr": "rate(kafka_producer_record_send_total[1m])",
          "legendFormat": "Published ({{client_id}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "type": "stat",
      "title": "DLQ Messages Routed",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(kafka_producer_record_send_total{topic=~.*dlq.*}[5m]))",
          "legendFormat": "DLQ Routing Count"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "DLQ Routing Rate",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "rate(kafka_producer_record_send_total{topic=~.*dlq.*}[1m])",
          "legendFormat": "{{topic}}"
        }
      ]
    }
  ]
}
